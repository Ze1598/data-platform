.venv/
.claude/
__pycache__/
*.py[cod]
.env
.DS_Store

# Local k8s Secret manifests -- plaintext dummy credentials for the local
# learning cluster (never real secrets), but not committed on principle,
# same as .env. Each has a tracked *.example sibling as the template to
# copy from (see .env/.env.example for the same convention).
frontend/k8s/postgres-credentials-secret.yaml
metadata/k8s/secret.yaml
orchestration/k8s/postgres-credentials-secret.yaml
query-engine/minio/secret.yaml
query-engine/polaris/secret.yaml
.pytest_cache/
*.egg-info/
data-lake/
# dbt/data_platform/ retired -- every domain under dbt/domains/<domain>/
# (see Roadmap.md "multi-project dbt split") has the same generated-output
# shape the single shared project used to, so these are glob patterns now,
# not one hardcoded path per file.
dbt/domains/*/target/
dbt/domains/*/dbt_packages/
dbt/domains/*/package-lock.yml
dbt/domains/*/logs/
dbt/domains/*/profiles/.user.yml
dbt/domains/*/models/serve/generated/
dbt/domains/*/models/model/intermediate/generated/
dbt/domains/*/models/model/ods/generated/
dbt/domains/*/models/staging/generated/
dbt/domains/*/models/staging/_sources.yml
orchestration/dagster_data_platform/dagster_data_platform/pipeline_generated.py
orchestration/dagster_data_platform/dagster_data_platform/clean_source_tables_generated.py

# DAGSTER_HOME runtime state (telemetry, compute logs, IO manager pickled
# storage, log queue) — only dagster.yaml itself is source, everything
# else here is generated by `dagster dev` runs.
orchestration/dagster_home/*
!orchestration/dagster_home/dagster.yaml
