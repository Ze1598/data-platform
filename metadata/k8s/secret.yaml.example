# Plaintext for local learning-cluster convenience only — matches .env.example.
# Not how this would be handled against a real cluster (would use a proper
# secrets manager / sealed-secrets / external-secrets instead).
#
# Copy this file to secret.yaml (gitignored) before running `just start` --
# see .env.example for the same convention.
apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: metadata
type: Opaque
stringData:
  POSTGRES_USER: platform
  POSTGRES_PASSWORD: platform
  POSTGRES_DB: platform_metadata
