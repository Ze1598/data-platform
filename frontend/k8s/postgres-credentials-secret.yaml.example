# Same plaintext-for-local-convenience Secret as metadata/k8s/secret.yaml
# and orchestration/k8s/postgres-credentials-secret.yaml, duplicated into
# the frontend namespace -- Secrets are namespace-scoped.
#
# Copy this file to postgres-credentials-secret.yaml (gitignored) before
# running `just start` -- see .env.example for the same convention.
apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: frontend
type: Opaque
stringData:
  POSTGRES_USER: platform
  POSTGRES_PASSWORD: platform
  POSTGRES_DB: platform_metadata
