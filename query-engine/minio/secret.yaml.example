# Plaintext for local learning-cluster convenience only — same rationale as
# the other Secrets in this repo.
#
# Copy this file to secret.yaml (gitignored) before running `just start` --
# see .env.example for the same convention.
apiVersion: v1
kind: Secret
metadata:
  name: minio-credentials
  namespace: query-engine
type: Opaque
stringData:
  MINIO_ROOT_USER: admin
  MINIO_ROOT_PASSWORD: password
