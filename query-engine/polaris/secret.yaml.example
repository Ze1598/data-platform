# Plaintext for local learning-cluster convenience only — same rationale as
# metadata/k8s/secret.yaml. POLARIS_BOOTSTRAP_CREDENTIALS is the realm's root
# principal (realm,clientId,clientSecret) — Polaris self-bootstraps its schema
# and root credentials on first start when this is set.
#
# Copy this file to secret.yaml (gitignored) before running `just start` --
# see .env.example for the same convention.
apiVersion: v1
kind: Secret
metadata:
  name: polaris-credentials
  namespace: query-engine
type: Opaque
stringData:
  QUARKUS_DATASOURCE_USERNAME: platform
  QUARKUS_DATASOURCE_PASSWORD: platform
  QUARKUS_DATASOURCE_JDBC_URL: jdbc:postgresql://postgres.metadata.svc.cluster.local:5432/polaris_db
  POLARIS_BOOTSTRAP_CREDENTIALS: "POLARIS,root,s3cr3t"
  # Same root/s3cr3t credential as POLARIS_BOOTSTRAP_CREDENTIALS above, just
  # in the clientId:clientSecret shape Trino's iceberg.rest-catalog.oauth2.credential
  # property wants (Polaris's own bootstrap format is realm,clientId,clientSecret --
  # a different shape) -- consumed via query-engine/trino/values.yaml's envFrom,
  # not duplicated into a separate credential file.
  POLARIS_OAUTH2_CREDENTIAL: "root:s3cr3t"
